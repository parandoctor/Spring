<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">

<!--
    MyBatis 主配置文件（mybatis-config.xml）

    作用：
    1. 全局设置（settings）—— 影响 MyBatis 运行时行为
    2. 类型别名（typeAliases）—— 简化 XML 中的类名书写
    3. 环境配置（environments）—— 数据源与事务管理器（与 Spring 集成时通常由 Spring 管理）
    4. 映射器注册（mappers）—— 告诉 MyBatis 去哪里找 SQL 映射文件

    注意：与 Spring 集成时，数据源和事务管理由 Spring 容器接管，
    这里的 environments 可省略，仅保留 settings 和 typeAliases。
-->
<configuration>

    <!-- ==================== 全局设置 ==================== -->
    <settings>
        <!-- 驼峰命名自动映射：数据库字段 user_name → Java 属性 userName -->
        <setting name="mapUnderscoreToCamelCase" value="true"/>

        <!-- 延迟加载开关 -->
        <setting name="lazyLoadingEnabled" value="true"/>

        <!-- 积极加载改为按需加载 -->
        <setting name="aggressiveLazyLoading" value="false"/>

        <!-- 日志实现：STDOUT_LOGGING 将 SQL 输出到控制台 -->
        <setting name="logImpl" value="STDOUT_LOGGING"/>

        <!-- 允许在 SQL 语句中使用列标签（别名）代替列名 -->
        <setting name="useColumnLabel" value="true"/>

        <!-- 缓存开关 -->
        <setting name="cacheEnabled" value="true"/>
    </settings>

    <!-- ==================== 类型别名 ==================== -->
    <typeAliases>
        <!-- 方式一：逐个注册 -->
        <typeAlias type="com.spring.demo.model.User" alias="User"/>

        <!-- 方式二：批量扫描（推荐）—— 别名默认为类名首字母小写 -->
        <!-- <package name="com.spring.demo.model"/> -->
    </typeAliases>

    <!--
        与 Spring 集成时，以下 environments 和 mappers 由 SqlSessionFactoryBean
        和 MapperScannerConfigurer 管理，此处可省略。
    -->

</configuration>
